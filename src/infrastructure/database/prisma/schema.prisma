generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Aligné sur 10_branch_service.sql + public_id pour l'API (convention projet)
model BranchTable {
  id         String    @id @default(uuid()) @db.Uuid
  public_id  String    @unique
  code       String?   @unique @db.VarChar(10)
  name       String    @db.VarChar(160)
  city       String?   @db.VarChar(120)
  address    String?   @db.VarChar(240)
  email      String?   @db.VarChar(200)
  phone      String?   @db.VarChar(40)
  manager_id String?   @db.Uuid
  is_active  Boolean   @default(true)
  opened_at  DateTime? @db.Date
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz

  employees EmployeeTable[]

  @@index([is_active], map: "idx_branches_active")
  @@map("branches")
}

model EmployeeTable {
  id         String       @id @default(uuid()) @db.Uuid
  public_id  String       @unique
  user_id    String?      @db.Uuid
  full_name  String       @db.VarChar(160)
  email      String       @unique @db.VarChar(200)
  phone      String?      @db.VarChar(40)
  role       String       @db.VarChar(20)
  branch_id  String?      @db.Uuid
  branch     BranchTable? @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  is_active  Boolean      @default(true)
  hired_at   DateTime?    @db.Date
  created_at DateTime     @default(now()) @db.Timestamptz
  updated_at DateTime     @updatedAt @db.Timestamptz

  @@index([branch_id], map: "idx_employees_branch")
  @@index([role], map: "idx_employees_role")
  @@map("employees")
}
