  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:e2e": "PORT=3001 nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:cov": "vitest run --coverage",
    "test:unit": "vitest run __tests__/units",
    "test:e2e": "DOTENV_CONFIG_PATH=.env.test vitest run __tests__/e2e",
    "test:integration": "DOTENV_CONFIG_PATH=.env.test vitest run --fileParallelism=false __tests__/integrations"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
